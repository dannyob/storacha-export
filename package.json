    "better-sqlite3": "^12.8.0",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "multiformats": "^13.4.2",
    "ora": "^9.3.0",
    "pino": "^10.3.1",
    "undici": "^7.24.6"
  },
  "devDependencies": {
